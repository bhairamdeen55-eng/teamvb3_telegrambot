# ── Bot ───────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=your_bot_username

# Apna Telegram ID daalo — comma se alag karo agar multiple hain
# Example: 123456789
# Example multiple: 123456789,987654321
ADMIN_IDS=123456789

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///data/bot.db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ── AI / OpenAI ───────────────────────────────────────────────
AI_PROVIDER=openai
AI_API_KEY=sk-proj-your_openai_api_key_here
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=2048
VISION_MODEL=gpt-4o-mini

# ── Throttling ────────────────────────────────────────────────
THROTTLE_RATE=3
THROTTLE_BURST=5

# ── Webhook (Railway pe false rakho) ──────────────────────────
USE_WEBHOOK=false
WEBHOOK_URL=
WEBHOOK_PORT=8443
WEBHOOK_SECRET=

# ── Security ──────────────────────────────────────────────────
# python3 -c "import secrets; print(secrets.token_hex(16))"
ENCRYPTION_KEY=your_random_32_char_key_here
# python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_random_secret_key_here
SESSION_TTL=86400

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
SENTRY_DSN=

# ── Subscription ──────────────────────────────────────────────
FREE_TRIAL_DAYS=7
SUBSCRIPTION_CHECK_INTERVAL=3600
